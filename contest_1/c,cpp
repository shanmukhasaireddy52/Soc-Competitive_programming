#include <iostream>
#include <vector>
#include <bits/stdc++.h>
#include <cstring>
#include <algorithm>
using namespace std;

int main(){
    int t;cin>>t;
    while (t--) {
        int n;
        cin >> n;
        vector<int> need(n);

        for (int i = 0; i < n; i++)
            cin >> need[i];

        bool ok = true;

        for (int len = n; len >= 1 && ok; len--) {
            bool found = false;

            for (int l = 0; l + len <= n && !found; l++) {
                bool good = true;
                for (int i = l; i < l + len; i++) {
                    if (need[i] == 0) {
                        good = false;
                        break;
                    }
                }

                if (good) {
                    found = true;
                    for (int i = l; i < l + len; i++)
                        need[i]--;
                }
            }

            if (!found)
                ok = false;
        }

        if (ok)
            cout << "YES\n";
        else
            cout << "NO\n";
    }

    return 0;
}
